STOCKS_TELEGRAM_BOT_TOKEN=STOCKS_TELEGRAM_BOT_TOKEN
STOCKS_TELEGRAM_CHANNEL_ID=STOCKS_TELEGRAM_CHANNEL_ID
STOCKS_TELEGRAM_ADMIN_BOT_TOKEN=STOCKS_TELEGRAM_ADMIN_BOT_TOKEN
STOCKS_TELEGRAM_ADMIN_ID=STOCKS_TELEGRAM_ADMIN_ID
STOCKS_TELEGRAM_DEV_BOT_TOKEN=STOCKS_TELEGRAM_DEV_BOT_TOKEN
STOCKS_TELEGRAM_DEV_ID=STOCKS_TELEGRAM_DEV_ID
CRYPTO_TELEGRAM_BOT_TOKEN=CRYPTO_TELEGRAM_BOT_TOKEN
CRYPTO_TELEGRAM_CHANNEL_ID=CRYPTO_TELEGRAM_CHANNEL_ID
CRYPTO_TELEGRAM_ADMIN_BOT_TOKEN=CRYPTO_TELEGRAM_ADMIN_BOT_TOKEN
CRYPTO_TELEGRAM_ADMIN_ID=CRYPTO_TELEGRAM_ADMIN_ID
CRYPTO_TELEGRAM_DEV_BOT_TOKEN=CRYPTO_TELEGRAM_DEV_BOT_TOKEN
CRYPTO_TELEGRAM_DEV_ID=CRYPTO_TELEGRAM_DEV_ID
SIMULATE_TRADINGVIEW_TRAFFIC=true
IS_TESTING_TELEGRAM=true
TRADING_VIEW_IPS='52.89.214.238,34.212.75.30,54.218.53.128,52.32.178.7'
TRADING_VIEW_WEBHOOK_SECRET=TRADING_VIEW_WEBHOOK_SECRET
DISABLE_TELEGRAM=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
STOCKS_JOB_START_LOCAL_HOUR=9
STOCKS_JOB_START_LOCAL_MINUTE=0
CRYPTO_JOB_START_LOCAL_HOURS=8,16
CRYPTO_JOB_START_LOCAL_MINUTES=45,15
JOB_DELAY_TOLERANCE_SECOND=1800
CRYPTO_SIGNAL_DB_PATH=var/crypto_signal/crypto_signal.sqlite3
CRYPTO_SIGNAL_TEST_DB_PATH=var/crypto_signal/crypto_signal.test.sqlite3
# Optional private/operator signal recipient. Leave empty to use CRYPTO_TELEGRAM_ADMIN_ID.
CRYPTO_SIGNAL_RECIPIENT_ID=
# Built-in symbols BTC/ETH/SOL can omit CoinMarketCap ids; other symbols use SYMBOL:CMC_ID.
CRYPTO_SIGNAL_TRACKED_UNIVERSE=BTC,ETH,SOL,TAO:22974
CRYPTO_SIGNAL_WATCHLIST=BTC,ETH,SOL
CRYPTO_SIGNAL_DYNAMIC_CANDIDATE_MIN_PRICE_USD=0
CRYPTO_SIGNAL_DYNAMIC_CANDIDATE_MIN_VOLUME_24H=50000000
# Phase-2 BTC market-regime context is disabled by default in tests.
CRYPTO_SIGNAL_MARKET_REGIME_ENABLED=false
# Supported runtime provider for this slice. `binance` is reserved for fallback work.
CRYPTO_SIGNAL_MARKET_REGIME_PROVIDER=coinalyze
# Keep empty in tracked test config so tests do not initialize a live provider key.
COINALYZE_API_KEY=
# Explicit Coinalyze BTC perpetual symbols. Empty keeps collection skipped.
CRYPTO_SIGNAL_MARKET_REGIME_COINALYZE_SYMBOLS=
# Coinalyze history interval. Intraday backfill is capped by retained datapoints.
CRYPTO_SIGNAL_MARKET_REGIME_INTERVAL=1hour
# Historical window for regime summaries. With 1hour cadence, 30d stays under the cap.
CRYPTO_SIGNAL_MARKET_REGIME_BACKFILL_DAYS=30
MESSARI_ASSET_METRICS_SHA256=MESSARI_ASSET_METRICS_SHA256
RESEND_API_KEY=RESEND_API_KEY
EMAIL_RECIPIENT=EMAIL_RECIPIENT
EMAIL_SENDER=EMAIL_SENDER
REDIS_KEY=REDIS_KEY
RESEND_REDIS_TEMPLATE_ID=RESEND_REDIS_TEMPLATE_ID
SHOULD_COMPARE_STOCKS_VOLUME_RANK=true
DISPLAY_VIX_FUTURES_CONTANGO_DECREASE_PAST_N_DAYS=true
ENV=dev
SELENIUM_REMOTE_MODE=true
SELENIUM_SERVER_HOST=http://chrome:4444
SELENIUM_STEALTH=false
SHOULD_SEND_STOCKS_SENTIMENT_MESSAGE=false
API_AUTH_TOKEN=API_AUTH_TOKEN
AUTH_EXCLUDE_ENDPOINTS=''
MAILJET_API_KEY=MAILJET_API_KEY
MAILJET_SECRET_KEY=MAILJET_SECRET_KEY
MAILJET_API_BASE_URL=https://api.mailjet.com
MAILJET_LETSENCRYPT_TEMPLATE_ID=
MAILJET_REDIS_TEMPLATE_ID=
